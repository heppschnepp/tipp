# Server Configuration
PORT=3001

# Database (MSSQL)
DB_SERVER=sqlserver
DB_PORT=1433
DB_NAME=tipp
DB_USER=lportal
DB_PASSWORD=lportal

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# WC2026 API (required for automatic match result fetching)
# Get your free key from https://wc2026api.com
WC2026_API_KEY=your_wc2026_api_key_here

# PDF Export: Path to flag images (PNG files)
# In Docker: mounted at /app/public/flags from client/public/flags
# In dev: defaults to ../client/public/flags relative to server working dir
FLAGS_DIR=/app/public/flags
